{
  "name": "@drapp/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many -t serve --projects=api,web --parallel",
    "dev:web": "nx serve web",
    "dev:api": "nx serve api",
    "build": "nx run-many -t build --projects=api,web",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "prod:build": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:restart": "docker compose -f docker-compose.prod.yml up -d --build --force-recreate",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:ps": "docker compose -f docker-compose.prod.yml ps",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f --tail=200",
    "prod:logs:api": "docker compose -f docker-compose.prod.yml logs -f --tail=200 api",
    "prod:logs:web": "docker compose -f docker-compose.prod.yml logs -f --tail=200 web"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.4.1",
    "@nx/nest": "^22.4.1",
    "@nx/next": "^22.4.1",
    "@nx/node": "22.4.1",
    "@nx/web": "22.4.1",
    "@nx/webpack": "22.4.1",
    "@nx/workspace": "22.4.1",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "20.19.9",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.23",
    "nx": "22.4.1",
    "postcss": "^8.5.6",
    "prettier": "~3.6.2",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
